# # palisades.sf
#Select NIFC perimeters for Palisades and Eaton Fires
wgis <- st_read(paste0(dir, 'WFIGS_Interagency//Perimeters.shp'))
# plot(wgis)
la.fires <- wgis %>% filter(poly_Incid %in% c('Eaton', 'PALISADES'))
la.fires <- st_transform(la.fires, c)
# st_crs(la.fires)
#Add a 100-meter buffer to the fire
la.fires.buffer <- la.fires %>% st_buffer(dist = 100)
plot(la.fires.buffer)
# plot(la.fires)
# eaton <- la.fires %>% filter(poly_Incid %in% c('Eaton'))
# palisades <- la.fires %>% filter(poly_Incid %in% c('PALISADES'))
#
# #Filter for intersection with Palisades
# eaton.in = lengths(st_intersects(frap, eaton)) > 0
#
# palisades.in = lengths(st_intersects(frap, palisades)) > 0
# la.frap <- frap %>% st_filter(la.fires, .predicates = st_intersects)
# plot(la.fires)
la.tracts.2020 <- tracts(
state = "CA",
county = "Los Angeles",
cb = FALSE,
resolution = "500k",
year = 2020
)
la.tracts.2020 <- st_transform(la.tracts.2020, c)
# glimpse(la.tracts.2020)
# plot(la.tracts.2020)
la.fire.tracts <- la.tracts.2020 %>% st_filter(la.fires.buffer, .predicates = st_intersects)
la.fire.tracts %>% plot()
#Label the tracts by which fire they intersect
la.fire.tracts <- la.fire.tracts %>% mutate(which.fire = case_when(lengths(st_intersects(la.fire.tracts, la.fires.buffer %>% filter(poly_Incid == 'Eaton'))) > 0 ~ 'Eaton', lengths(st_intersects(la.fire.tracts, la.fires.buffer %>% filter(poly_Incid == 'PALISADES'))) > 0 ~ 'Palisades'))
# plot(la.fire.tracts)
# la.blocks.2020 <- blocks(
#                   state = "CA",
#                   county = "Los Angeles",
#                   year = 2020)
#Palisades Census Tracts
