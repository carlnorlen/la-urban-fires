# plot(palisades.fire.blocks)
#
# #Eaton/Altadena Census Blocks
# altadena.fire.blocks <- la.fire.blocks %>% st_filter(altadena.sf, .predicates = st_within)
# plot(altadena.fire.blocks)
#Merge the Census Blocks for the Eaton and Palisades Fires
# combined.fire.blocks <- rbind(altadena.fire.blocks, palisades.fire.blocks)
# plot(combined.fire.blocks)\
#Merge the census tracts for Eaton and Palisades together
# combined.fire.tracts <- rbind(altadena.fire.tracts, palisades.fire.tracts)
# plot(la.fire.tracts)
#Combine the census blocks into two polygons
la.fire.union <- la.fire.tracts %>%
# Filter for Urban Census Blocks
filter(NAME != '9304') %>%
#Groupy by the 2025 Fire
group_by(which.fire) %>%
#Combine the census blocks
st_union()
# plot(la.fire.union)
#California counties
la <- counties(state = "CA", cb = FALSE, resolution = "500k", year = 2020)
# head(la)
#LA county
la.county <- la %>% filter(NAME == "Los Angeles")
la.county <- st_transform(la.county, crs = c)
#FRAP intersection
# frap %>%
#   st_intersects(la.county, sparse = FALSE)
#LA County FRAP perimeters
frap.la <- frap %>% st_filter(la.fires, .predicates = st_intersects)
frap.la <- frap.la %>% mutate(year = as.numeric(frap.la$YEAR_))
#Adding a label with the fires
frap.la <- frap.la %>% mutate(which.fire = case_when(lengths(st_intersects(frap.la, la.fires %>% filter(poly_Incid == 'Eaton'))) > 0 ~ 'Eaton', lengths(st_intersects(frap.la, la.fires %>% filter(poly_Incid == 'PALISADES'))) > 0 ~ 'Palisades'))
# frap.la %>% head()
# plot(frap.la %>% filter(YEAR_ >= 1910) %>% st_intersection(la.fire.union))
#Total Fire Area
#FRAP intersection with census tracts
frap.la.intersect <- frap.la %>% st_intersection(la.fire.union)
#Add the area of the clipped fires
frap.la.intersect <- frap.la.intersect %>% mutate(area = set_units(st_area(frap.la.intersect), 'acre'))
#LA Fires intersection with census blocks
wgis.la.intersect <- st_buffer(la.fires, 0) %>% st_intersection(la.fire.union)
# plot(wgis.la.intersect)
#Get the areas of the 2025 fires
wgis.la.intersect <- wgis.la.intersect %>% mutate(area = set_units(st_area(wgis.la.intersect), 'acre'))
#Create the census tract burned area
la.fires.clipped <- st_buffer(la.fires,0) %>% st_intersection(la.fire.tracts)
# plot(la.fires.clipped)
la.fire.clipped <- la.fires.clipped %>% mutate(fire.area.2025.acre = set_units(st_area(la.fires.clipped), 'acre'))
# glimpse(la.fire.clipped)
#Add 2025 fire area, tract area, and 2025 % affected to the layers
tracts.join <- la.fire.tracts %>%
left_join(as.data.frame(la.fire.clipped) %>% select(c('NAME', 'fire.area.2025.acre')), by = 'NAME') %>%
mutate(tract.area = set_units(st_area(la.fire.tracts), 'acre'))
tracts.join$fire.area.2025.acre[is.na(tracts.join$fire.area.2025.acre)] <- 0
tracts.join <- tracts.join %>% mutate(fire.area.2025.pct = (fire.area.2025.acre / tract.area) * 100)
#Try adding the earlier fire year areas to the data
#LA County Parcels combined with DINS data
dins.la <- st_read(paste0(dir, '2025_Parcels_with_DINS_data_1400140593036023148.gpkg'))
dins.la %>% glimpse()
dins.la %>% as.data.frame() %>% select(Fire_Name) %>% unique()
dins.la <- st_transform(dins.la, c)
dins.la <- dins.la %>% mutate(DAMAGE_1.num = case_when(DAMAGE_1 == 'No Damage' ~ 1, DAMAGE_1 == 'Affected (1-9%)' ~ 2, DAMAGE_1 == 'Minor (10-25%)' ~ 3, DAMAGE_1 == 'Major (26-50%)' ~ 4, DAMAGE_1 == 'Destroyed (>50%)' ~ 5))
dins.la <- dins.la %>% mutate(YearBuilt.category = case_when(as.numeric(YearBuilt1) <= 2008 ~ '2008 & Before', as.numeric(YearBuilt1) > 2008 ~ 'After 2008'))
#Add the Core Logic
#Consider switching to the CSV data
core.logic <- st_read(paste0(dir, 'CoreLogic Data//Point Files//og_06037_points_pro_2.shp'))
# glimpse(core.logic)
dins.core.join <- dins.la %>% left_join(as.data.frame(core.logic), by = c('AIN_1' = 'APN'))
#Join Census tracts with spatial within join
dins.core.tract.join <- dins.core.join %>%
#Filter by Fire Name
filter(Fire_Name %in% c('Eaton', 'Palisades')) %>%
#Join the DINS data to the census tract that it intersects with
st_join(la.fire.tracts, join = st_intersects)
# glimpse(dins.core.tract.join)
#Test to calculate the mean property value
#Add a filter for single family homes only (or something like that)
#Select just the Residential and Single Home properties
# summary(dins.core.tract.join)
ggplot() + geom_point(data = )
dins.core.tract.join %>%
#Convert the data to data frame
as.data.frame %>%
#Filter the data
filter(!is.na(TOT_VAL) & UseDescription == 'Single' & UseType == 'Residential' & DINS_Count >= 1 & !is.na(YearBuilt1)) %>%
#Group the data by census tract
group_by(TRACTCE) %>%
#Summarize the data
summarize(value.median = median(TOT_VAL),
count = n())
#Summarize the total structures and median home value for each tract
tract.summary <- dins.core.tract.join %>%
#Convert the data to data frame
as.data.frame %>%
#Filter the data
filter(!is.na(TOT_VAL) & UseDescription == 'Single' & UseType == 'Residential' & DINS_Count >= 1 & !is.na(YearBuilt1) & !is.na(DAMAGE_1) & DAMAGE_1 != 'Inaccessible') %>%
group_by(TRACTCE) %>%
#Summarize the data
summarize(tract.value.median = median(TOT_VAL), destroy.count = sum(DAMAGE_1.num == 5), damage.count = sum(DAMAGE_1.num %in% c(2,3,4)), before.2008.count = sum(as.numeric(YearBuilt1) <= 2008), after.2008.count = sum(as.numeric(YearBuilt1) > 2008), structure.count = n()) %>%
#Add more data columns
mutate(destroy_pct = (destroy.count / structure.count) * 100, damage_pct = (damage.count / structure.count) * 100, before_2008_pct = (before.2008.count / structure.count) * 100, after_2008_pct = (after.2008.count / structure.count) * 100)
tracts.dins <- tracts.join %>% left_join(tract.summary, by = 'TRACTCE')
#Export the data as a CSV file
write.csv(as.data.frame(tracts.dins) %>% select(-c('geometry')), file = "C://Users//CarlNorlen//mystuff//data//urban-fires//census_tracts_burned_area_20250304.csv")
