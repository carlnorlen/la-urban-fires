# # plot(palisades.fire.tracts)
#
# #Eaton/Altadena Census Blocks
# altadena.fire.tracts <- la.fire.tracts %>% st_filter(altadena.sf, .predicates = st_within) %>% filter(NAME != '9304')
# plot(altadena.fire.tracts)
# la.blocks.2020 <- st_transform(la.blocks.2020, c)
# la.fire.blocks <- la.blocks.2020 %>% st_filter(la.fires, .predicates = st_intersects)
#Label the blocks by which fire they intersect
# la.fire.blocks <- la.fire.blocks %>% mutate(which.fire = case_when(lengths(st_intersects(la.fire.blocks, la.fires %>% filter(poly_Incid == 'Eaton'))) > 0 ~ 'Eaton', lengths(st_intersects(la.fire.blocks, la.fires %>% filter(poly_Incid == 'PALISADES'))) > 0 ~ 'Palisades'))
#
